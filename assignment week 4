C
#include <stdio.h>
#include <stdbool.h>

#define MAX 1000

typedef struct {
    int q[MAX];
    int front, rear, size, k;
} MyCircularQueue;

MyCircularQueue createQueue(int k) {
    MyCircularQueue cq;
    cq.front = 0; cq.rear = -1; cq.size = 0; cq.k = k;
    return cq;
}

bool enQueue(MyCircularQueue *cq, int value) {
    if (cq->size == cq->k) return false;
    cq->rear = (cq->rear + 1) % cq->k;
    cq->q[cq->rear] = value;
    cq->size++;
    return true;
}

bool deQueue(MyCircularQueue *cq) {
    if (cq->size == 0) return false;
    cq->front = (cq->front + 1) % cq->k;
    cq->size--;
    return true;
}

int Front(MyCircularQueue *cq) { return cq->size == 0 ? -1 : cq->q[cq->front]; }
int Rear(MyCircularQueue *cq) { return cq->size == 0 ? -1 : cq->q[cq->rear]; }
bool isEmpty(MyCircularQueue *cq) { return cq->size == 0; }
bool isFull(MyCircularQueue *cq) { return cq->size == cq->k; }

🔹 3. 101. Symmetric Tree
C++
class Solution {
public:
    bool isSymmetric(TreeNode* root) {
        if (!root) return true;
        return isMirror(root->left, root->right);
    }

    bool isMirror(TreeNode* t1, TreeNode* t2) {
        if (!t1 && !t2) return true;
        if (!t1 || !t2) return false;
        return (t1->val == t2->val) &&
               isMirror(t1->left, t2->right) &&
               isMirror(t1->right, t2->left);
    }
};

Java
class Solution {
    public boolean isSymmetric(TreeNode root) {
        if (root == null) return true;
        return isMirror(root.left, root.right);
    }

    private boolean isMirror(TreeNode t1, TreeNode t2) {
        if (t1 == null && t2 == null) return true;
        if (t1 == null || t2 == null) return false;
        return (t1.val == t2.val) &&
               isMirror(t1.left, t2.right) &&
               isMirror(t1.right, t2.left);
    }
}

C
#include <stdbool.h>

struct TreeNode {
    int val;
    struct TreeNode *left;
    struct TreeNode *right;
};

bool isMirror(struct TreeNode* t1, struct TreeNode* t2) {
    if (!t1 && !t2) return true;
    if (!t1 || !t2) return false;
    return (t1->val == t2->val) &&
           isMirror(t1->left, t2->right) &&
           isMirror(t1->right, t2->left);
}

bool isSymmetric(struct TreeNode* root) {
    if (!root) return true;
    return isMirror(root->left, root->right);
}