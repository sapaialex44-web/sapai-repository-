        rear = -1;
        size = 0;
    }

    public boolean enQueue(int value) {
        if (isFull()) return false;
        rear = (rear + 1) % k;
        q[rear] = value;
        size++;
        return true;
    }

    public boolean deQueue() {
        if (isEmpty()) return false;
        front = (front + 1) % k;
        size--;
        return true;
    }

    public int Front() { return isEmpty() ? -1 : q[front]; }
    public int Rear() { return isEmpty() ? -1 : q[rear]; }
